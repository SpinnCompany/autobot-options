# ─── AutobotOptions — Environment Variables ───
# Copy to .env and customize for your deployment.
# Domain: options.autobotsignal.io (GCP production)
#
# This is a DEMO-ONLY trading terminal.
# All trading is simulated client-side via DemoEngine.
# No backend API or database is required.

# WebSocket URL for real broker data (optional).
# Leave empty to use the built-in DemoEngine with simulated prices.
# Set to a real WebSocket URL to connect to a live broker adapter.
# Example: VITE_WS_URL=wss://your-broker.com/ws
VITE_WS_URL=
